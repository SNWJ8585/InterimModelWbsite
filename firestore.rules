rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'snwj8585@gmail.com' || 
        request.auth.uid == '2MZy1HTRP5hp58wIcHmPFR5uVTB2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 10 && id.matches('^[1-5]$');
    }

    function isValidSlot(data) {
      return data.keys().hasAll(['title', 'modelPath', 'updatedAt']) &&
             data.title is string && data.title.size() <= 100 &&
             data.modelPath is string && data.modelPath.size() <= 1000 &&
             data.updatedAt == request.time;
    }

    match /slots/{slotId} {
      allow read: if true;
      allow write: if isSignedIn() && isOwner() && isValidId(slotId) && isValidSlot(request.resource.data);
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == request.auth.uid;
      allow write: if false;
    }
  }
}
