rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      // For this app, we'll use a specific UID or check if the user is in an 'admins' collection.
      // Since we don't have a list yet, we'll allow the first user who sets it up or use a hardcoded one for now.
      // Better: Check if user document exists in 'admins' collection.
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[1-5]$');
    }

    function isValidSlot(data) {
      return data.keys().hasAll(['title', 'modelPath', 'updatedAt']) &&
             data.keys().size() <= 4 &&
             data.title is string && data.title.size() <= 100 &&
             data.modelPath is string && data.modelPath.size() <= 500 &&
             data.updatedAt == request.time;
    }

    match /slots/{slotId} {
      allow read: if true;
      allow write: if isSignedIn() && isOwner() && isValidId(slotId) && isValidSlot(request.resource.data);
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console for safety
    }
  }
}
